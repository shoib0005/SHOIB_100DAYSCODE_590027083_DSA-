#include <stdio.h>
#include <string.h>

void reverse(char str[], int index) {
    // Base case
    if (index < 0)
        return;

    // Print current character
    printf("%c", str[index]);

    // Recursive call
    reverse(str, index - 1);
}

int main() {
    char str[100];

    // Input
    scanf("%s", str);

    int len = strlen(str);

    // Output (reversed string)
    reverse(str, len - 1);

    return 0;
}
